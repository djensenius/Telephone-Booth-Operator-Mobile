default_platform(:ios)

API_KEY = {
  key_id: "XP65R4N5A2",
  issuer_id: "69a6de7e-a5f5-47e3-e053-5b8c7c11a4d1",
  key_filepath: File.expand_path("~/.appstoreconnect/AuthKey_XP65R4N5A2.p8")
}

APP_NAME           = "Telephone Booth Operator"
APP_SKU            = "tb-operator-mobile"
PRIMARY_BUNDLE_ID  = "org.davidjensenius.TelephoneBoothOperatorMobile"
WIDGETS_BUNDLE_ID  = "#{PRIMARY_BUNDLE_ID}.widgets"
WATCH_BUNDLE_ID    = "#{PRIMARY_BUNDLE_ID}.watch"
PRIMARY_LANGUAGE   = "en-CA"
APP_GROUP_ID       = "group.org.davidjensenius.TelephoneBoothOperatorMobile"

# App Store keywords are applied per version localization via Spaceship because
# this repo cannot carry a `keywords.txt` metadata file.
KEYWORDS = "operator,console,booth,phone,installation,dashboard,monitor,status,calls,messages"

# Developer Portal capabilities each bundle ID must have enabled, derived from
# the targets' .entitlements files. Managed signing (Xcode Cloud) only succeeds
# when every entitlement maps to an enabled App ID capability; a missing one
# fails provisioning-profile generation and `-exportArchive` exits 70.
REQUIRED_CAPABILITIES = {
  PRIMARY_BUNDLE_ID => %w[PUSH_NOTIFICATIONS APP_GROUPS], # aps-environment + app-groups
  WIDGETS_BUNDLE_ID => %w[APP_GROUPS],                    # app-groups
  WATCH_BUNDLE_ID   => %w[PUSH_NOTIFICATIONS APP_GROUPS]  # aps-environment + app-groups
}.freeze

platform :ios do
  before_all do
    app_store_connect_api_key(**API_KEY)
  end

  desc "Register the Developer Portal bundle IDs (main app + widgets + watch) using the App Store Connect API key. Idempotent."
  lane :register_bundle_ids do
    require "spaceship"

    token = Spaceship::ConnectAPI::Token.create(
      key_id: API_KEY[:key_id],
      issuer_id: API_KEY[:issuer_id],
      filepath: API_KEY[:key_filepath]
    )
    Spaceship::ConnectAPI.token = token

    bundle_ids = [
      [PRIMARY_BUNDLE_ID, APP_NAME],
      [WIDGETS_BUNDLE_ID, "#{APP_NAME} Widgets"],
      [WATCH_BUNDLE_ID,   "#{APP_NAME} Watch"]
    ]

    bundle_ids.each do |identifier, name|
      existing = Spaceship::ConnectAPI::BundleId.find(identifier)
      if existing
        UI.success("Bundle ID already exists on Developer Portal: #{identifier}")
      else
        UI.message("Registering bundle ID on Developer Portal: #{identifier}")
        Spaceship::ConnectAPI::BundleId.create(
          name: name,
          identifier: identifier,
          platform: "UNIVERSAL"
        )
        UI.success("Created bundle ID: #{identifier}")
      end
    end

    ensure_capabilities
  end

  desc "Ensure each Developer Portal bundle ID has the App ID capabilities its " \
       ".entitlements require (Push, App Groups). Idempotent. Note: the App " \
       "Store Connect API can enable the App Groups capability but cannot " \
       "associate a specific App Group - assign #{APP_GROUP_ID} to each App ID " \
       "in the portal (or let Xcode managed signing associate it)."
  lane :ensure_capabilities do
    require "spaceship"

    token = Spaceship::ConnectAPI::Token.create(
      key_id: API_KEY[:key_id],
      issuer_id: API_KEY[:issuer_id],
      filepath: API_KEY[:key_filepath]
    )
    Spaceship::ConnectAPI.token = token

    REQUIRED_CAPABILITIES.each do |identifier, required|
      bundle_id = Spaceship::ConnectAPI::BundleId.find(identifier)
      unless bundle_id
        UI.error("Bundle ID not registered yet: #{identifier} (run register_bundle_ids)")
        next
      end

      present = (bundle_id.get_capabilities || []).map(&:capability_type)
      required.each do |capability|
        if present.include?(capability)
          UI.success("#{identifier}: #{capability} already enabled")
        else
          UI.message("#{identifier}: enabling #{capability}")
          bundle_id.create_capability(capability)
          UI.success("#{identifier}: enabled #{capability}")
        end
      end
    end

    UI.important("App Groups capability is enabled, but associating #{APP_GROUP_ID} " \
                 "to each App ID is portal-only (the App Store Connect API does not " \
                 "expose App Groups). Xcode managed signing associates it automatically " \
                 "on the next archive/export; otherwise assign it under each App ID in " \
                 "the Developer Portal.")
  end

  desc "Create the App Store Connect app record (iOS + macOS). Requires Apple ID + 2FA - the App Store Connect API key cannot create new apps."
  lane :create_app_record do
    # Apple does not expose app creation through the App Store Connect API
    # (the `/apps` endpoint only allows GET/UPDATE, not CREATE), so this lane
    # falls back to the legacy `produce` action which uses Apple ID + 2FA.
    # Run this from an interactive shell; you will be prompted for your 2FA code.
    produce(
      app_identifier: PRIMARY_BUNDLE_ID,
      app_name: APP_NAME,
      sku: APP_SKU,
      language: PRIMARY_LANGUAGE,
      platforms: ["ios", "osx"],
      skip_devcenter: true # bundle IDs are registered by `register_bundle_ids`
    )
  end

  desc "End-to-end app registration: bundle IDs (API key) + App Store Connect record (interactive Apple ID)."
  lane :create_app do
    register_bundle_ids
    create_app_record
  end

  desc "Print the App Store Connect app record + version states (diagnostic)."
  lane :asc_status do
    require "spaceship"
    token = Spaceship::ConnectAPI::Token.create(
      key_id: API_KEY[:key_id],
      issuer_id: API_KEY[:issuer_id],
      filepath: API_KEY[:key_filepath]
    )
    Spaceship::ConnectAPI.token = token

    app = Spaceship::ConnectAPI::App.find(PRIMARY_BUNDLE_ID)
    if app.nil?
      UI.important("APP NOT FOUND on App Store Connect for #{PRIMARY_BUNDLE_ID}")
      next
    end
    UI.success("APP FOUND: #{app.name} (id=#{app.id}) sku=#{app.sku}")
    begin
      app.get_app_store_versions.each do |v|
        UI.message("  version #{v.version_string} platform=#{v.platform} state=#{v.app_store_state}")
        begin
          locs = v.get_app_store_version_localizations
          UI.message("    locales: #{locs.map(&:locale).join(', ')}")
          locs.each do |loc|
            sets = loc.get_app_screenshot_sets
            counts = sets.map { |s| "#{s.screenshot_display_type}=#{s.app_screenshots&.size || 0}" }
            UI.message("    #{loc.locale} screenshots: #{counts.join(', ')}")
          end
        rescue StandardError => e
          UI.error("    localization error: #{e.class}: #{e.message}")
        end
        begin
          build = v.get_build
          UI.message("    build: #{build ? build.version : 'NONE ATTACHED'}")
        rescue StandardError => e
          UI.error("    build error: #{e.class}: #{e.message}")
        end
      end
    rescue StandardError => e
      UI.error("  versions error: #{e.class}: #{e.message}")
    end
  end

  desc "Build and upload the iOS app to TestFlight"
  lane :beta do
    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M")
    )
    build_app(
      project: "TelephoneBoothOperatorMobile.xcodeproj",
      scheme: "TBOperatorMobile",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates"
    )
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      app_identifier: PRIMARY_BUNDLE_ID
    )
  end

  # Keywords are set programmatically because the App Store keyword field is
  # uploaded per version localization and this repo cannot carry a
  # `keywords.txt` metadata file (see KEYWORDS at the top of this file).
  desc "Upload metadata + screenshots for every platform to App Store Connect (no binaries)."
  lane :upload_store_metadata do
    deliver_platform("ios", "ios")
    deliver_platform("appletvos", "appletv")
    deliver_platform("xros", "visionos")
    deliver_platform("osx", "mac")
    set_keywords_all(KEYWORDS)
  end
end

# Uploads text metadata and the platform's screenshots for one App Store
# platform without touching the binary. Safe to re-run.
def deliver_platform(platform, screenshots_subdir)
  shots = File.expand_path("screenshots/#{screenshots_subdir}", __dir__)
  unless Dir.exist?(shots)
    UI.important("No screenshots dir for #{platform} (#{shots}); skipping.")
    return
  end
  deliver(
    app_identifier: PRIMARY_BUNDLE_ID,
    platform: platform,
    metadata_path: File.expand_path("metadata", __dir__),
    screenshots_path: shots,
    skip_binary_upload: true,
    overwrite_screenshots: true,
    run_precheck_before_submit: false,
    submit_for_review: false,
    automatic_release: false,
    force: true
  )
end

# Sets the keyword field on the editable version localization of every
# platform, working around the missing keywords.txt metadata file.
def set_keywords_all(keywords)
  require "spaceship"
  token = Spaceship::ConnectAPI::Token.create(
    key_id: API_KEY[:key_id],
    issuer_id: API_KEY[:issuer_id],
    filepath: API_KEY[:key_filepath]
  )
  Spaceship::ConnectAPI.token = token
  app = Spaceship::ConnectAPI::App.find(PRIMARY_BUNDLE_ID)
  return UI.important("App not found; cannot set keywords.") if app.nil?

  app.get_app_store_versions.each do |version|
    next unless version.app_store_state == "PREPARE_FOR_SUBMISSION"

    version.get_app_store_version_localizations.each do |loc|
      loc.update(attributes: { keywords: keywords })
      UI.success("Set keywords for #{version.platform} #{loc.locale}")
    end
  end
end

platform :mac do
  before_all do
    app_store_connect_api_key(**API_KEY)
  end

  desc "Build and upload the macOS app to TestFlight"
  lane :beta do
    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M")
    )
    build_app(
      project: "TelephoneBoothOperatorMobile.xcodeproj",
      scheme: "TBOperatorMobileMac",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates"
    )
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      app_identifier: PRIMARY_BUNDLE_ID
    )
  end
end
